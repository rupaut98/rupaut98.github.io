---
import { profile } from '../data/site';
const links = [
  { name: 'Work', href: '#work' },
  { name: 'Experience', href: '#experience' },
  { name: 'About', href: '#about' },
];
---

<header
  class="ledger sticky top-0 z-50 backdrop-blur-md"
  style="background-color: color-mix(in srgb, var(--surface) 80%, transparent); border-top: 1px solid color-mix(in srgb, var(--ink) 14%, transparent);"
>
  <nav
    class="mx-auto flex max-w-6xl items-center justify-between px-5 py-4 sm:px-8"
  >
    <a href="#top" class="font-display text-lg tracking-tight">{profile.name}</a
    >

    <div class="flex items-center gap-1 sm:gap-2">
      {
        links.map((l) => (
          <a
            href={l.href}
            class="eyebrow hidden px-3 py-2 text-ink/60 transition-colors hover:text-ink sm:inline-block"
          >
            {l.name}
          </a>
        ))
      }
      <a
        href={`mailto:${profile.email}`}
        class="eyebrow ml-1 border border-ink/20 bg-ink px-4 py-2 text-surface transition-opacity hover:opacity-80"
      >
        Contact
      </a>

      <button
        id="theme-toggle"
        aria-label="Toggle theme"
        class="ml-1 flex h-9 w-9 items-center justify-center border border-ink/20 text-ink/70 transition-colors hover:text-ink"
      >
        <svg
          class="hidden h-4 w-4 dark:block"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          viewBox="0 0 24 24"
          ><circle cx="12" cy="12" r="5"></circle><path
            d="M12 1v2M12 21v2M4.2 4.2l1.4 1.4M18.4 18.4l1.4 1.4M1 12h2M21 12h2M4.2 19.8l1.4-1.4M18.4 5.6l1.4-1.4"
          ></path></svg
        >
        <svg
          class="h-4 w-4 dark:hidden"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          viewBox="0 0 24 24"
          ><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"
          ></path></svg
        >
      </button>
    </div>
  </nav>
</header>

<script is:inline>
  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    const dark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', dark ? 'dark' : 'light');
  });
</script>
