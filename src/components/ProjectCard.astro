---
import type { Project } from '../data/site';
const { project } = Astro.props as { project: Project };
const Tag = project.url ? 'a' : 'div';
---

<Tag
  {...project.url
    ? { href: project.url, target: '_blank', rel: 'noreferrer' }
    : {}}
  class="reveal group flex flex-col border border-ink/12 bg-ink/[0.02] transition-colors hover:border-ink/30"
>
  <div class="flex flex-1 flex-col gap-3 p-5">
    <div class="flex items-start justify-between gap-3">
      <h3 class="font-display text-xl leading-tight text-ink/95">
        {project.title}
      </h3>
      {
        project.url && (
          <svg
            class="mt-1 h-4 w-4 shrink-0 text-ink/40 transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5 group-hover:text-accent"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            viewBox="0 0 24 24"
          >
            <path d="M7 17L17 7M17 7H8M17 7v9" />
          </svg>
        )
      }
    </div>

    <p class="text-sm leading-relaxed text-ink/60">{project.blurb}</p>

    <div class="mt-auto flex flex-wrap gap-1.5 pt-2">
      {
        project.tags.map((t) => (
          <span class="eyebrow border border-ink/15 px-1.5 py-0.5 text-[9px] text-ink/50">
            {t}
          </span>
        ))
      }
    </div>
  </div>
</Tag>
