---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import ProjectCard from '../components/ProjectCard.astro';
import {
  profile,
  about,
  skills,
  experience,
  projects,
  openSource,
  education,
} from '../data/site';
---

<Base>
  <span id="top"></span>
  <Nav />

  <main class="mx-auto max-w-6xl px-5 sm:px-8">
    <!-- HERO -->
    <section class="ledger reveal flex flex-col gap-6 px-1 py-20 sm:py-28">
      <div class="flex flex-col gap-6 px-4 sm:px-8">
        <span class="eyebrow w-fit bg-accent px-3 py-1.5 text-[#0a0a0a]">
          {profile.role}
        </span>
        <h1 class="font-display text-5xl leading-[0.95] tracking-tight text-ink/95 sm:text-7xl">
          {profile.name}
        </h1>
        <p class="max-w-2xl text-sm leading-relaxed text-ink/60 sm:text-base">
          {profile.pitch}
        </p>
        <div class="mt-2 flex flex-wrap items-center gap-3">
          <a
            href="#work"
            class="eyebrow border border-ink/20 bg-ink px-5 py-3 text-surface transition-opacity hover:opacity-80"
          >
            View Work →
          </a>
          <a
            href={profile.resumeUrl}
            class="eyebrow border border-ink/20 px-5 py-3 text-ink/80 transition-colors hover:bg-ink/[0.06]"
          >
            Resume
          </a>
          {
            profile.openToWork && (
              <span class="eyebrow flex items-center gap-2 px-2 text-ink/50">
                <span class="h-2 w-2 rounded-full bg-lime" /> {profile.openToWork}
              </span>
            )
          }
        </div>
      </div>
    </section>

    <!-- WORK -->
    <section id="work" class="ledger px-1 py-14">
      <div class="px-4 sm:px-8">
        <div class="mb-8 flex items-baseline justify-between">
          <h2 class="eyebrow text-ink/50">Selected Work</h2>
          <span class="eyebrow text-ink/30">{String(projects.length).padStart(2, '0')}</span>
        </div>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-3">
          {projects.map((project) => <ProjectCard project={project} />)}
        </div>
      </div>
    </section>

    <!-- EXPERIENCE -->
    <section id="experience" class="ledger px-1 py-14">
      <div class="px-4 sm:px-8">
        <h2 class="eyebrow mb-8 text-ink/50">Experience</h2>
        <div class="flex flex-col">
          {
            experience.map((job) => (
              <div class="reveal grid gap-3 border-t border-ink/12 py-7 sm:grid-cols-[200px_1fr]">
                <div class="flex flex-col gap-1">
                  <span class="eyebrow text-ink/40">{job.range}</span>
                  {job.url ? (
                    <a
                      href={job.url}
                      target="_blank"
                      rel="noreferrer"
                      class="font-display text-lg text-ink/95 transition-colors hover:text-accent"
                    >
                      {job.company}
                    </a>
                  ) : (
                    <span class="font-display text-lg text-ink/95">{job.company}</span>
                  )}
                  <span class="text-xs text-ink/50">{job.title}</span>
                </div>
                <ul class="flex flex-col gap-2.5">
                  {job.bullets.map((b) => (
                    <li class="flex gap-3 text-sm leading-relaxed text-ink/65">
                      <span class="mt-2 h-1 w-1 shrink-0 bg-accent" />
                      {b}
                    </li>
                  ))}
                </ul>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- OPEN SOURCE -->
    <section class="ledger px-1 py-14">
      <div class="px-4 sm:px-8">
        <h2 class="eyebrow mb-8 text-ink/50">Open Source</h2>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
          {
            openSource.map((os) => (
              <a
                href={os.url}
                target="_blank"
                rel="noreferrer"
                class="reveal group flex flex-col gap-2 border border-ink/12 bg-ink/[0.02] p-5 transition-colors hover:border-ink/30"
              >
                <div class="flex items-center justify-between">
                  <h3 class="font-display text-lg text-ink/95 group-hover:text-accent">{os.name}</h3>
                  <span class="eyebrow text-ink/40">{os.stars}</span>
                </div>
                <p class="text-sm leading-relaxed text-ink/60">{os.blurb}</p>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ABOUT -->
    <section id="about" class="ledger px-1 py-14">
      <div class="grid gap-10 px-4 sm:px-8 md:grid-cols-[1.4fr_1fr]">
        <div class="reveal flex flex-col gap-4">
          <h2 class="eyebrow mb-2 text-ink/50">About</h2>
          {about.map((p) => <p class="text-sm leading-relaxed text-ink/70">{p}</p>)}
        </div>
        <div class="reveal flex flex-col gap-6">
          <div>
            <h3 class="eyebrow mb-3 text-ink/40">Education</h3>
            <p class="font-display text-ink/95">{education.school}</p>
            <p class="text-sm text-ink/60">{education.degree}</p>
            <p class="mt-1 text-xs text-ink/45">{education.range}</p>
            <p class="mt-1 text-xs text-ink/45">{education.detail}</p>
          </div>
          <div>
            <h3 class="eyebrow mb-3 text-ink/40">Stack</h3>
            <div class="flex flex-wrap gap-1.5">
              {
                skills.map((s) => (
                  <span class="eyebrow border border-ink/15 px-2 py-1 text-[9px] text-ink/55">{s}</span>
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CONTACT -->
    <section id="contact" class="ledger reveal flex flex-col items-center gap-6 px-4 py-24 text-center">
      <h2 class="font-display text-4xl leading-tight tracking-tight text-ink/95 sm:text-5xl">
        Let's build something.
      </h2>
      <p class="max-w-md text-sm text-ink/55">
        Open to software, full-stack, and AI roles — and interesting collaborations. My DMs are open.
      </p>
      <a
        href={`mailto:${profile.email}`}
        class="eyebrow border border-ink/20 bg-ink px-6 py-3 text-surface transition-opacity hover:opacity-80"
      >
        {profile.email}
      </a>
    </section>
  </main>

  <!-- FOOTER -->
  <footer class="ledger mx-auto max-w-6xl px-5 sm:px-8">
    <div class="flex flex-col items-center justify-between gap-4 py-8 sm:flex-row">
      <span class="eyebrow text-ink/40">© {profile.name}</span>
      <div class="flex gap-5">
        <a href={profile.socials.github} target="_blank" rel="noreferrer" class="eyebrow text-ink/50 hover:text-ink">GitHub</a>
        <a href={profile.socials.linkedin} target="_blank" rel="noreferrer" class="eyebrow text-ink/50 hover:text-ink">LinkedIn</a>
        <a href={`mailto:${profile.email}`} class="eyebrow text-ink/50 hover:text-ink">Email</a>
      </div>
    </div>
  </footer>
</Base>
